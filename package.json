{
  "name": "naad-official",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--disable-warning=DEP0060 next dev -p 4000",
    "build": "node scripts/build-production.js",
    "start": "cross-env NODE_OPTIONS=--disable-warning=DEP0060 node scripts/start-server.js",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false node ./node_modules/eslint/bin/eslint.js . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=false node ./node_modules/eslint/bin/eslint.js . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next node_modules/.cache .turbo dist build out .swc .eslintcache"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-image-crop": "^11.0.10",
    "react-image-crop": "^11.0.4",
    "react-select": "^5.8.0",
    "sweetalert2": "^11.26.21"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
