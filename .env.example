# Backend API base (optional; default: https://api-naad.jojolapatech.com)
# NEXT_PUBLIC_BACKEND_URL=https://api-naad.jojolapatech.com
# BACKEND_URL=https://api-naad.jojolapatech.com
# API_INTERNAL_URL=http://127.0.0.1:8080

# NextAuth session (HttpOnly JWT cookie — same flow as erp-web)
NEXTAUTH_SECRET=replace-with-a-long-random-secret-min-32-chars
# NEXTAUTH_URL=http://localhost:4000
# NEXTAUTH_SESSION_MAX_SECONDS=2592000

# Optional: server-side bearer so /horoscope can load published readings without user login
# when the Java API still protects /event/horoscope/list. Prefer a real public backend route later.
# PUBLIC_API_BEARER=eyJhbGciOi...

# Required for user/role/permission/menu API calls. Gateway returns "XSRF Token Missing" (403) without it.
# Use the AES-encrypted (Base64) token — same value you send in X-XSRF-TOKEN in Swagger/Postman/curl.
# Example (try this for api-naad.jojolapatech.com; if 403 persists, get the correct value from backend):
NEXTAUTH_XSRF_TOKEN=BquLOJXXt2ng415MpvK4a8F0CF/w/1iawsnFqHzPGeo=

# Google Maps (birth chart place picker) — copy from erp-web .env.local if shared
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

